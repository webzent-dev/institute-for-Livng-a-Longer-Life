APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Shippo Configuration
SHIPPO_API_KEY=shippo_test_3168e42fdf0e7ddbb5e4bd70a7967e488e875d0b
SHIPPO_ENABLED=true

# Institute Address (for fallback shipping)
INSTITUTE_ADDRESS_LINE_1="123 Institute St"
INSTITUTE_CITY="New York"
INSTITUTE_STATE="NY"
INSTITUTE_ZIP_CODE="10001"
INSTITUTE_COUNTRY="US"
INSTITUTE_EMAIL="contact@institute.com"
INSTITUTE_PHONE="+1-555-0123"

# Address Validation Configuration
ADDRESS_VALIDATION_ENABLED=true
ADDRESS_VALIDATION_STRICT=false

# Google Maps Address Validation (Primary Provider)
GOOGLE_MAPS_VALIDATION_ENABLED=true
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# For Testing - You can use this temporary key:
# GOOGLE_MAPS_API_KEY=AIzaSyBhXvX9Y7Z8W6Q5R4T3Y2U1I0O9P8L7K6J

# USPS Address Validation (Enabled)
USPS_VALIDATION_ENABLED=true
USPS_USER_ID=your_usps_user_id_here

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_MODE=live

# Shopify App (Standard Process integration)
SHOPIFY_APP_API_KEY=
SHOPIFY_APP_URL=
SHOPIFY_APP_WEBHOOK_SECRET=
STANDARD_PROCESS_STORE_URL=
